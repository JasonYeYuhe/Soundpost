      }
    },
    "Export & share is a Pro feature.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "書き出しと共有は Pro の機能です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导出与分享是 Pro 功能。"
          }
        }
      }
    },
    "Export & share your cards": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カードを書き出して共有"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导出并分享你的卡片"

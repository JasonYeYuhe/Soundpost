          "stringUnit": {
            "state": "translated",
            "value": "上野公园"
          }
        }
      }
    },
    "Unlock the theme pack with Soundpost Pro.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Soundpost Pro でテーマパックを解除しましょう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过 Soundpost Pro 解锁主题包。"
          }
        }
      }
    },
    "Unseal": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "封印を解除"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "解除封印"
          }
        }
      }
    },
    "Up to 5 minutes. Tap to start.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最長5分まで。タップして開始。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "最长 5 分钟。点按开始。"
          }
        }
      }
    },
    "Up to 60 seconds. Tap to start.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最大60秒。タップして開始。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "最长 60 秒。点按开始。"
          }
        }
      }
    },
    "Up to a minute of real sound — rain, a café, a voice — kept as a beautiful, mood-tinted card.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "雨の音、カフェ、誰かの声——最長1分のリアルな音を、気分の色をまとった美しいカードに。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "最长一分钟的真实声音——雨声、咖啡馆、某个声音——化作一张随心情上色的精美卡片。"
          }
        }
      }
    },
    "What is this?": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これは何ですか？"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这是什么？"
          }
        }
      }
    },
    "Yesterday": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "昨日"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "昨天"
          }
        }
      }
    },
    "You captured this %@": {
      "comment": "Resurface reveal subtitle; %@ is a relative time like \"8 months ago\"",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@にこの音を残しました"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你在%@录下了这段声音"
          }
        }
      }
    },
    "You have Soundpost Pro. Thank you for supporting Soundpost.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Soundpost Pro をご利用中です。Soundpost を応援してくれてありがとうございます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你已拥有 Soundpost Pro。感谢你对 Soundpost 的支持。"
          }
        }
      }
    },
    "Your data": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたのデータ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的数据"
          }
        }
      }
    },
    "Your iCloud storage is full, so new capsules stay on this device for now.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloudの容量がいっぱいのため、新しいカプセルは当面この端末に保存されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的 iCloud 空间已满，新胶囊暂时只保存在本机。"
          }
        }
      }
    },
    "Your purchases were restored.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "購入を復元しました。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已恢复你的购买。"
          }
        }
      }
    },
    "iCloud & delivery": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloudと配信"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 与投递"
          }
        }
      }
    },
    "push.echo.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {

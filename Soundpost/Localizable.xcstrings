        "ja" : { "stringUnit" : { "state" : "translated", "value" : "このカプセルを削除しますか？" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "删除这个胶囊？" } }
      }
    },
    "Discard & re-record" : {
      "localizations" : {
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "破棄して録り直す" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "放弃并重录" } }
